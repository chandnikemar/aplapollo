<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ================= MAIN APP THEME ================= -->

    <style name="Base.Theme.Apolloapl"
        parent="Theme.Material3.DayNight.NoActionBar">
        <!-- ================= PRIMARY ================= -->
        <item name="colorPrimary">@color/primaryColor</item>
        <item name="colorOnPrimary">@android:color/white</item>

        <item name="colorPrimaryContainer">@color/primaryLight</item>
        <item name="colorOnPrimaryContainer">@color/primaryDark</item>

        <!-- ================= SECONDARY ================= -->
        <item name="colorSecondary">@color/secondaryColor</item>
        <item name="colorOnSecondary">@android:color/white</item>

        <item name="colorSecondaryContainer">@color/secondaryLight</item>

        <!-- ================= STATUS BAR ================= -->
        <item name="android:statusBarColor">@color/statusBarColor</item>

        <!-- ================= APP BACKGROUND ================= -->
        <item name="android:windowBackground">@color/bgcolor</item>

        <item name="colorSurface">@android:color/white</item>

        <item name="colorOnSurface">@color/text_dark</item>

        <!-- ================= MATERIAL STYLES ================= -->

        <!-- Buttons -->
        <item name="materialButtonStyle">
            @style/Widget.Apollo.MaterialButton
        </item>

        <!-- Text Input -->
        <item name="textInputStyle">
            @style/Widget.Apollo.TextInputLayout
        </item>

        <!-- Cards -->
        <item name="materialCardViewStyle">
            @style/Widget.Apollo.CardView
        </item>

        <!-- Text -->
        <item name="textAppearanceHeadlineSmall">
            @style/TextAppearance.Apollo.Headline
        </item>

        <item name="textAppearanceBodyMedium">
            @style/TextAppearance.Apollo.Body
        </item>

    </style>

    <!-- ================= MAIN THEME ================= -->
    <style name="Theme.Apolloapl"
        parent="Base.Theme.Apolloapl" />

    <!-- ================= BUTTON ================= -->
    <style name="Widget.Apollo.MaterialButton"
        parent="Widget.Material3.Button">

        <item name="cornerRadius">12dp</item>

        <item name="android:minHeight">50dp</item>

        <item name="backgroundTint">@color/primaryColor</item>

        <item name="android:textColor">@android:color/white</item>

        <item name="android:textStyle">bold</item>

        <item name="android:textSize">15sp</item>

        <item name="iconTint">@android:color/white</item>

        <item name="rippleColor">@color/primaryLight</item>

    </style>

    <!-- ================= TEXT INPUT ================= -->
    <style name="Widget.Apollo.TextInputLayout"
        parent="Widget.Material3.TextInputLayout.OutlinedBox">

        <item name="boxCornerRadiusTopStart">12dp</item>

        <item name="boxCornerRadiusTopEnd">12dp</item>

        <item name="boxCornerRadiusBottomStart">12dp</item>

        <item name="boxCornerRadiusBottomEnd">12dp</item>

        <item name="boxStrokeColor">@color/primaryColor</item>

        <item name="hintTextColor">@color/text_hint</item>

    </style>

    <!-- ================= CARD ================= -->
    <style name="Widget.Apollo.CardView"
        parent="Widget.Material3.CardView.Elevated">

        <item name="cardCornerRadius">14dp</item>

        <item name="cardElevation">3dp</item>

        <item name="strokeWidth">1dp</item>

        <item name="strokeColor">@color/light_border</item>

        <item name="cardBackgroundColor">@android:color/white</item>

    </style>

    <!-- ================= HEADLINE ================= -->
    <style name="TextAppearance.Apollo.Headline"
        parent="TextAppearance.Material3.HeadlineSmall">

        <item name="android:textColor">@color/text_dark</item>

        <item name="android:textStyle">bold</item>

    </style>

    <!-- ================= BODY ================= -->
    <style name="TextAppearance.Apollo.Body"
        parent="TextAppearance.Material3.BodyMedium">

        <item name="android:textColor">@color/text_light</item>

    </style>


</resources>