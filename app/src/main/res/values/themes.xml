<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base Light Theme -->
    <style name="Base.Theme.Apolloapl"
        parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Primary -->
        <item name="colorPrimary">@color/rippleColor</item>
        <item name="colorOnPrimary">@android:color/white</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/orange</item>
        <item name="colorOnSecondary">@android:color/white</item>

        <!-- Background -->
        <item name="android:windowBackground">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/text_light</item>

        <!-- Button -->
        <item name="materialButtonStyle">
            @style/Widget.Apollo.MaterialButton
        </item>

        <!-- Text -->
        <item name="textAppearanceHeadlineSmall">
            @style/TextAppearance.Apollo.Headline
        </item>

        <item name="textAppearanceBodyMedium">
            @style/TextAppearance.Apollo.Body
        </item>

    </style>

<!--    &lt;!&ndash; Main Theme &ndash;&gt;-->
<!--    <style name="Theme.Apolloapl" parent="Base.Theme.Apolloapl" />-->

    <!-- Button -->
    <style name="Widget.Apollo.MaterialButton"
        parent="Widget.Material3.Button">

        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@color/primary_light</item>
        <item name="android:textColor">@android:color/white</item>

    </style>

    <!-- Text -->
    <style name="TextAppearance.Apollo.Headline"
        parent="TextAppearance.Material3.HeadlineSmall">

        <item name="android:textColor">@color/primary_light</item>

    </style>

    <style name="TextAppearance.Apollo.Body"
        parent="TextAppearance.Material3.BodyMedium">

        <item name="android:textColor">@color/text_light</item>

    </style>

</resources>
