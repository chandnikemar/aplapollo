<?xml version="1.0" encoding="utf-8"?>
<layout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- HEADER -->
        <include
            android:id="@+id/idLayoutHeader"
            layout="@layout/action_bar_comman_hedaer_layout" />

        <!-- MAIN SCROLL -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- TOP INFO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:id="@+id/textInputMaterial"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Material Code"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="@color/colorAccent"/>

                    <TextView
                        android:id="@+id/textJobNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Job #1001"
                        android:textStyle="bold"
                        android:textSize="15sp"/>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#DADADA"
                    android:layout_marginBottom="10dp"/>

                <!-- TOP DETAILS -->
                <!-- ================= Mother + Grade + Weight ================= -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layoutMotherCoilBatch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp">

                    <!-- 60% left / 40% right -->
                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/guideline70"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintGuide_begin="236dp" />

                    <!-- Split left into 2 -->
                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/guideline35"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintGuide_begin="142dp" />

                    <!-- Mother Barcode -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilMotherCoil"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:hint="Mother Barcode"
                        app:boxBackgroundMode="outline"
                        android:enabled="true"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/guideline35"
                        app:layout_constraintTop_toTopOf="parent"
                        android:layout_marginEnd="4dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/tvMotherCoil"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:textColor="@color/black"
                            android:padding="8dp"
                            android:textSize="12sp"
                            android:focusable="false"
                            android:clickable="false"
                            android:maxLines="1"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Grade -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilGrade"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:hint="Grade"
                        app:boxBackgroundMode="outline"
                        app:endIconMode="dropdown_menu"
                        app:layout_constraintStart_toEndOf="@id/guideline35"
                        app:layout_constraintEnd_toStartOf="@id/guideline70"
                        app:layout_constraintTop_toTopOf="@id/tilMotherCoil">

                        <AutoCompleteTextView
                            android:id="@+id/etGrade"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:padding="12dp"
                            android:textColor="@color/black"
                            android:textSize="12sp"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Weight -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilWeight"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:hint="Weight"
                        app:boxBackgroundMode="outline"
                        app:layout_constraintStart_toStartOf="@id/guideline70"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/tilMotherCoil"
                        android:layout_marginStart="4dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/tvBatchNumber"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:textSize="10sp"
                            android:gravity="center_vertical|end"
                            android:textColor="@color/black"
                            android:padding="4dp"
                            android:maxLines="1"

                            android:focusable="false"
                            android:focusableInTouchMode="false"
                            android:clickable="false"
                            android:cursorVisible="false"
                            android:longClickable="false"
                            android:textIsSelectable="false"
                            android:inputType="numberDecimal"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
                <!-- ================= Summary Card ================= -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:strokeColor="#E0E0E0"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <!-- Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="3">

                            <!-- Allowance -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Tolerance +-"
                                    android:textColor="@color/grey"
                                    android:textSize="11sp"/>

                                <TextView
                                    android:id="@+id/tvAllowance"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0.00"
                                    android:textStyle="bold"
                                    android:textSize="14sp"
                                    android:textColor="@color/colorAccent"
                                    android:paddingTop="4dp"/>
                            </LinearLayout>

                            <!-- Divider -->
                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                android:background="#E0E0E0"/>

                            <!-- Scrap -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Scrap"
                                    android:textColor="@color/grey"
                                    android:textSize="11sp"/>

                                <TextView
                                    android:id="@+id/tvScrap"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0.00"
                                    android:textStyle="bold"
                                    android:textSize="14sp"
                                    android:textColor="@android:color/holo_red_dark"
                                    android:paddingTop="4dp"/>
                            </LinearLayout>

                            <!-- Divider -->
                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                android:background="#E0E0E0"/>

                            <!-- Output -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Output"
                                    android:textColor="@color/grey"
                                    android:textSize="11sp"/>

                                <TextView
                                    android:id="@+id/tvOutput"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0.00"
                                    android:textStyle="bold"
                                    android:textSize="14sp"
                                    android:textColor="@android:color/holo_green_dark"
                                    android:paddingTop="4dp"/>
                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>
                <!-- OUTPUT LIST -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerOutput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"
                    tools:listitem="@layout/dynamic_job_item"/>
<!--                <com.google.android.material.textfield.TextInputLayout-->
<!--                    android:id="@+id/layoutIronLoss"-->
<!--                    android:layout_width="match_parent"-->
<!--                    android:layout_height="wrap_content"-->
<!--                    android:layout_marginTop="10dp"-->
<!--                    android:hint="Iron Loss Weight">-->

<!--                    <com.google.android.material.textfield.TextInputEditText-->
<!--                        android:id="@+id/etIronLossWeight"-->
<!--                        android:layout_width="match_parent"-->
<!--                        android:layout_height="wrap_content"-->
<!--                        android:inputType="numberDecimal"-->
<!--                        android:maxLines="1" />-->

<!--                </com.google.android.material.textfield.TextInputLayout>-->


                <!-- ADD BUTTON -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="14dp">

                    <androidx.appcompat.widget.AppCompatImageButton
                        android:id="@+id/btnAddJob"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/card_green_gradient"
                        android:src="@android:drawable/ic_input_add"
                        android:padding="10dp"
                        app:tint="@android:color/white"/>
                </LinearLayout>

                <!-- BUTTONS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnSave"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:text="Save"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:background="@drawable/button_generate"
                        android:layout_marginEnd="6dp"/>

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnPrintBarcode"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:visibility="gone"
                        android:text="Print Barcode"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:background="@drawable/button_clear"
                        android:layout_marginStart="6dp"/>
                </LinearLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

</layout>