<?xml version="1.0" encoding="utf-8"?>
    <com.google.android.material.card.MaterialCardView
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="6dp"
        android:layout_marginVertical="4dp"
        app:cardCornerRadius="5dp"
        app:cardElevation="1dp"
        app:strokeWidth="1dp"
        app:strokeColor="#E5E7EB">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- TOP ROW -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Barcode -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
    <!--                <TextView-->
    <!--                    android:layout_width="wrap_content"-->
    <!--                    android:layout_height="wrap_content"-->
    <!--                    android:text="Barcode "-->
    <!--                    android:textColor="#6B7280"-->
    <!--                    android:textSize="10sp"/>-->

                    <TextView
                        android:id="@+id/tvBarcodeNo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BC-987654321"
                        android:textColor="#111827"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tvDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:text="22-05-2026 10:30 AM"
                            android:textColor="#6B7280"
                            android:textSize="10sp"/>
                    </LinearLayout>

                </LinearLayout>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/ivEye"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="6dp"
                    android:visibility="gone"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    app:backgroundTint="@android:color/transparent"
                    app:strokeWidth="0dp"
                    app:icon="@drawable/ic_eye"
                    app:iconSize="20dp"
                    app:iconTint="#2563EB"
                    app:iconGravity="textStart"/>
                <!-- Status -->
                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Completed"
                    android:textColor="#16A34A"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:background="@drawable/status_bg"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"/>
            </LinearLayout>

            <!-- DIVIDER -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="6dp"
                android:background="#ECECEC"/>

            <!-- DETAILS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Width -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Width"
                        android:textColor="#6B7280"
                        android:textSize="10sp"/>

                    <TextView
                        android:id="@+id/tvWidth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1200"
                        android:textColor="#111827"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Thickness -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thickness"
                        android:textColor="#6B7280"
                        android:textSize="10sp"/>

                    <TextView
                        android:id="@+id/tvThickness"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5.0"
                        android:textColor="#111827"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Grade -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Grade"
                        android:textColor="#6B7280"
                        android:textSize="10sp"/>

                    <TextView
                        android:id="@+id/tvGrade"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="S355"
                        android:textColor="#111827"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAction"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:layout_gravity="end"
                android:layout_marginTop="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="30dp"
                android:text="print"
                android:textAllCaps="false"
                android:textSize="11sp"
                app:backgroundTint="#2563EB"
                app:cornerRadius="5dp"
                app:icon="@android:drawable/ic_menu_revert"
                app:iconGravity="textStart"
                app:iconPadding="2dp"
                app:iconTint="@android:color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelete"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_gravity="end"
                android:layout_marginTop="6dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="30dp"
                android:text="Delete"
                android:textAllCaps="false"
                android:textSize="11sp"
                android:textColor="@android:color/white"
                app:backgroundTint="#DC2626"
                app:cornerRadius="5dp"
                app:icon="@android:drawable/ic_menu_delete"
                app:iconGravity="textStart"
                app:iconPadding="2dp"
                app:iconTint="@android:color/white" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>