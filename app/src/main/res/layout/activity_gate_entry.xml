<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <!-- Header -->
        <include
            android:id="@+id/idLayoutHeader"
            layout="@layout/action_bar_comman_hedaer_layout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Main Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="12dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            android:background="@color/white"
            app:layout_constraintTop_toBottomOf="@id/idLayoutHeader"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp"
                android:background="@color/lightblue">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    >

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gate Entry Form"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <!-- Transporter -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Transporter Name">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etTransporter"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Transporter Number">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etTransporterNo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Vehicle -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Vehicle No">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etVehicleNo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>




                    <!-- LR No -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="LR No"
                     >


                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etLrNo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:maxLength="15"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnSubmit"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Generate Gate Entry"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/button_generate"
                        android:textColor="@android:color/white"/>
                    <!-- Buttons -->
                    <TextView
                        android:id="@+id/tvGateEntryNo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Gate Entry No: -"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginTop="12dp"
                        android:visibility="gone"/>
                <LinearLayout
                    android:id="@+id/layoutCoilSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginTop="16dp">
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Coil No">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etCoilNo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnAddCoil"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Add Coil"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/button_generate"
                        android:textColor="@android:color/white"/>

                    <!-- Coil List -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvCoilList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:visibility="gone"/>

                    <!-- Final Submit -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnFinalSubmit"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Submit All Coils"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/button_generate"
                        android:textColor="@android:color/white"/>
                </LinearLayout>
                </LinearLayout>
            </ScrollView>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>