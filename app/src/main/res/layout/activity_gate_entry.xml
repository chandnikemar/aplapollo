<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F4F7FC">

        <!-- ================= HEADER ================= -->
        <include
            android:id="@+id/idLayoutHeader"
            layout="@layout/action_bar_comman_hedaer_layout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ================= CONTENT ================= -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fillViewport="true"
            android:clipToPadding="false"
            app:layout_constraintTop_toBottomOf="@id/idLayoutHeader"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">



                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <!-- ================= TITLE SECTION ================= -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                android:background="@drawable/bg_chip_light"
                                android:padding="10dp"
                                android:src="@drawable/ic_gate"
                                app:tint="@color/primaryDark" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Transport Details"
                                    android:textColor="#111827"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="Enter transporter and vehicle information"
                                    android:textColor="#6B7280"
                                    android:textSize="12sp" />

                            </LinearLayout>

                        </LinearLayout>

                        <!-- ================= TRANSPORTER CODE ================= -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            android:hint="Transporter Code"
                            app:boxBackgroundMode="outline"
                            app:boxCornerRadiusTopStart="14dp"
                            app:boxCornerRadiusTopEnd="14dp"
                            app:boxCornerRadiusBottomStart="14dp"
                            app:boxCornerRadiusBottomEnd="14dp"
                            app:boxStrokeColor="@color/primaryDark"
                            app:startIconDrawable="@drawable/ic_code"
                            app:startIconTint="@color/primaryDark">

                            <AutoCompleteTextView
                                android:id="@+id/etTransporterCode"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"

                                android:inputType="text"
                                android:minHeight="54dp"
                                android:paddingStart="4dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp"
                                android:textColor="#111827"
                                android:textSize="14sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- ================= TRANSPORTER NAME ================= -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:hint="Transporter Name"
                            app:boxBackgroundMode="outline"
                            app:boxCornerRadiusTopStart="14dp"
                            app:boxCornerRadiusTopEnd="14dp"
                            app:boxCornerRadiusBottomStart="14dp"
                            app:boxCornerRadiusBottomEnd="14dp"
                            app:boxStrokeColor="@color/primaryDark"
                            app:startIconDrawable="@drawable/ic_transporter"
                            app:startIconTint="@color/primaryDark">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etTransporterName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="54dp"
                                android:paddingStart="4dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp"
                                android:textColor="#111827"
                                android:textSize="14sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- ================= VEHICLE NUMBER ================= -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:hint="Vehicle Number"
                            app:boxBackgroundMode="outline"
                            app:boxCornerRadiusTopStart="14dp"
                            app:boxCornerRadiusTopEnd="14dp"
                            app:boxCornerRadiusBottomStart="14dp"
                            app:boxCornerRadiusBottomEnd="14dp"
                            app:boxStrokeColor="@color/primaryDark"
                            app:startIconDrawable="@drawable/ic_truck"
                            app:startIconTint="@color/primaryDark">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etVehicleNo"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="54dp"
                                android:paddingStart="4dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp"
                                android:textColor="#111827"
                                android:textSize="14sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- ================= LR NUMBER ================= -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:hint="LR Number"
                            app:boxBackgroundMode="outline"
                            app:boxCornerRadiusTopStart="14dp"
                            app:boxCornerRadiusTopEnd="14dp"
                            app:boxCornerRadiusBottomStart="14dp"
                            app:boxCornerRadiusBottomEnd="14dp"
                            app:boxStrokeColor="@color/primaryDark"
                            app:startIconDrawable="@drawable/ic_receipt"
                            app:startIconTint="@color/primaryDark">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etLrNo"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:maxLength="15"
                                android:minHeight="54dp"
                                android:paddingStart="4dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp"
                                android:textColor="#111827"
                                android:textSize="14sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- ================= SUBMIT BUTTON ================= -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSubmit"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:layout_marginTop="28dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="Generate Gate Entry"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/primaryDark"
                            app:cornerRadius="14dp"
                            app:icon="@drawable/ic_check"
                            app:iconGravity="textStart"
                            app:iconPadding="10dp"
                            app:iconTint="@null"
                            />

                    </LinearLayout>



        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>