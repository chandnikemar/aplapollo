<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F4F7FC"
        tools:context=".view.QualityCheckActivity">

        <!-- HEADER -->

        <include
            android:id="@+id/idLayoutHeader"
            layout="@layout/action_bar_comman_hedaer_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- SEARCH BAR -->

        <include
            android:id="@+id/commanInputRow"
            layout="@layout/comman_inputrow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            app:layout_constraintTop_toBottomOf="@id/idLayoutHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- EMPTY VIEW -->

        <LinearLayout
            android:id="@+id/layoutEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/commanInputRow"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:src="@drawable/ic_search"
                app:tint="#C5C5C5" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="No Coil Data Found"
                android:textColor="#424242"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Scan or search a coil batch number"
                android:textColor="#8A8A8A"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- MAIN CONTAINER -->

        <ScrollView
            android:id="@+id/layoutQcContainer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="visible"
            android:overScrollMode="never"
            android:scrollbars="none"
            app:layout_constraintTop_toBottomOf="@id/commanInputRow"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- DETAILS CARD -->

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- TITLE -->

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Coil Information"
                            android:textColor="#111111"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Fetched from SAP"
                            android:textColor="#7D7D7D"
                            android:textSize="12sp" />

                        <!-- DETAILS TABLE -->

                        <TableLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:stretchColumns="1">

                            <TableRow>

                                <TextView
                                    style="@style/QcLabel"
                                    android:text="Supplier Batch" />

                                <TextView
                                    android:id="@+id/column2_row1"
                                    style="@style/QcValue"
                                    tools:text="SUP001" />

                            </TableRow>

                            <TableRow>

                                <TextView
                                    style="@style/QcLabel"
                                    android:text="Supplier Name" />

                                <TextView
                                    android:id="@+id/column2_row2"
                                    style="@style/QcValue"
                                    tools:text="TATA Steel" />

                            </TableRow>

                            <TableRow>

                                <TextView
                                    style="@style/QcLabel"
                                    android:text="Weight (TON)" />

                                <TextView
                                    android:id="@+id/column2_row3"
                                    style="@style/QcValue"
                                    tools:text="15.250 TON" />

                            </TableRow>

                            <TableRow>

                                <TextView
                                    style="@style/QcLabel"
                                    android:text="Grade" />

                                <TextView
                                    android:id="@+id/column2_row4"
                                    style="@style/QcValue"
                                    tools:text="CRFH" />

                            </TableRow>

                            <TableRow>

                                <TextView
                                    style="@style/QcLabel"
                                    android:text="Thickness" />

                                <TextView
                                    android:id="@+id/column2_row5"
                                    style="@style/QcValue"
                                    tools:text="1.20" />

                            </TableRow>

                            <TableRow>

                                <TextView
                                    style="@style/QcLabel"
                                    android:text="Width" />

                                <TextView
                                    android:id="@+id/column2_row6"
                                    style="@style/QcValue"
                                    tools:text="1250" />

                            </TableRow>

                            <TableRow>

                                <TextView
                                    style="@style/QcLabel"
                                    android:text="GRN Number" />

                                <TextView
                                    android:id="@+id/column2_row8"
                                    style="@style/QcValue"
                                    tools:text="GRN00125" />

                            </TableRow>

                            <TableRow>

                                <TextView
                                    style="@style/QcLabel"
                                    android:text="GRN Date" />

                                <TextView
                                    android:id="@+id/column2_row9"
                                    style="@style/QcValue"
                                    tools:text="2026-05-27" />

                            </TableRow>

                            <TableRow>

                                <TextView
                                    style="@style/QcLabel"
                                    android:text="Material Code" />

                                <TextView
                                    android:id="@+id/column2_row_material_code"
                                    style="@style/QcValue"
                                    tools:text="MAT1025" />

                            </TableRow>

                        </TableLayout>

                        <!-- ACTION BUTTONS -->

                        <LinearLayout
                            android:id="@+id/layoutActionButtons"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="22dp"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/buttonLeft"
                                android:layout_width="0dp"
                                android:layout_height="54dp"
                                android:layout_weight="1"
                                android:text="Reject"
                                android:textAllCaps="false"
                                android:textSize="15sp"
                                app:backgroundTint="#E53935"
                                app:cornerRadius="14dp"
                                app:icon="@drawable/ic_clear"
                                app:iconPadding="8dp"
                                app:iconTint="@android:color/white" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/buttonRight"
                                android:layout_width="0dp"
                                android:layout_height="54dp"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:text="Approve"
                                android:textAllCaps="false"
                                android:textSize="15sp"
                                app:backgroundTint="#0A8F5A"
                                app:cornerRadius="14dp"
                                app:icon="@drawable/ic_check"
                                app:iconPadding="8dp"
                                app:iconTint="@null" />

                        </LinearLayout>

                        <!-- REJECT REMARK -->

                        <LinearLayout
                            android:id="@+id/rowRemarkSubmit"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:visibility="gone">

                            <EditText
                                android:id="@+id/etRemark"
                                android:layout_width="0dp"
                                android:layout_height="54dp"
                                android:layout_weight="1"
                                android:background="@drawable/rectangle_background"
                                android:hint="Enter rejection remark"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp"
                                android:textColor="#000000"
                                android:textColorHint="#8B8B8B"
                                android:textSize="14sp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/buttonASubmit"
                                android:layout_width="120dp"
                                android:layout_height="54dp"
                                android:layout_marginStart="10dp"
                                android:text="Submit"
                                android:textAllCaps="false"
                                android:textSize="14sp"
                                app:backgroundTint="#1565C0"
                                app:cornerRadius="14dp" />

                        </LinearLayout>

                        <!-- BARCODE SECTION -->
                        <LinearLayout
                            android:id="@+id/layoutBarcodeSection"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <!-- BARCODE CARD -->

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                app:cardCornerRadius="14dp"
                                app:cardElevation="2dp">

                                <LinearLayout
                                    android:id="@+id/barcodeContainer"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:orientation="vertical"
                                    android:padding="14dp">

                                    <ImageView
                                        android:id="@+id/barcodeImage"
                                        android:layout_width="220dp"
                                        android:layout_height="80dp"
                                        android:adjustViewBounds="true" />

                                    <TextView
                                        android:id="@+id/barcodeText"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="8dp"
                                        android:textColor="#000000"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        tools:text="QC000125" />

                                </LinearLayout>

                            </com.google.android.material.card.MaterialCardView>

                            <!-- BUTTON COLUMN -->

                            <LinearLayout
                                android:layout_width="130dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:gravity="center"
                                android:orientation="vertical">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/buttonPrintLabel"
                                    android:layout_width="match_parent"
                                    android:layout_height="52dp"
                                    android:text="Print Label"
                                    android:textAllCaps="false"
                                    android:textColor="@android:color/white"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    app:backgroundTint="#0A8F5A"
                                    app:cornerRadius="14dp"
                                    app:icon="@drawable/printer_white_on"
                                    app:iconPadding="6dp"
                                    app:iconTint="@android:color/white" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </ScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
