<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:paddingHorizontal="8dp">

        <!-- Logo -->
        <ImageView
            android:id="@+id/ivBackOrLogo"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/kvisibilitylogo" />

        <!-- Logout Button -->
        <LinearLayout
            android:id="@+id/logouticon"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_circle_white_20"
            android:gravity="center"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                app:srcCompat="@drawable/ic_logout" />

        </LinearLayout>

        <!-- User Info -->
        <LinearLayout
            android:id="@+id/userSection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/logouticon"
            app:layout_constraintTop_toTopOf="parent">

            <!-- User Initial -->
            <TextView
                android:id="@+id/tvAvatar"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_circle_blue"
                android:gravity="center"
                android:text="C"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- User Name -->
            <TextView
                android:id="@+id/profileTXt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:maxLines="1"
                android:text="Chandni"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>