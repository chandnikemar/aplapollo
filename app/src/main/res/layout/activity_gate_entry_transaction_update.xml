<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F4F7FC">

        <!-- Header -->
        <include
            android:id="@+id/idLayoutHeader"
            layout="@layout/action_bar_comman_hedaer_layout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Main Scroll -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fillViewport="true"
            app:layout_constraintTop_toBottomOf="@id/idLayoutHeader"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">



                <!-- GATE ENTRY CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="5dp"
                    app:cardElevation="4dp"
                    app:strokeColor="#D6E4FF"
                    app:strokeWidth="1dp"
                    app:cardBackgroundColor="#EEF4FF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gate Entry Number"
                            android:textColor="#5B6475"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvGateEntryNo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="A126E00010"
                            android:textColor="#1A73E8"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- TRANSPORT DETAILS CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="5dp"
                    app:cardElevation="3dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#ECECEC">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Transport Information"
                            android:textColor="#111827"
                            android:textSize="19sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="16dp" />

                        <!-- TRANSPORTER -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="8dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Transporter"
                                android:textColor="#6B7280"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvTransporter"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="end"
                                android:text="GEA1001"
                                android:textColor="#111827"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- TRANSPORTER CODE -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="8dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Transporter Code"
                                android:textColor="#6B7280"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvTransporterNo"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="end"
                                android:text="1500101"
                                android:textColor="#111827"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- VEHICLE -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="8dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Vehicle No"
                                android:textColor="#6B7280"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvVehicle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="end"
                                android:text="MH04XY5678"
                                android:textColor="#111827"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- LR NO -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="8dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="LR Number"
                                android:textColor="#6B7280"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvLrNo"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="end"
                                android:text="7412586368"
                                android:textColor="#111827"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ADD COIL CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/layoutCoilSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="5dp"
                    app:cardElevation="3dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#ECECEC">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Add Coil"
                            android:textColor="#111827"
                            android:textSize="19sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="14dp" />

                        <!-- Coil Input -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Enter Coil Number"
                            app:boxBackgroundMode="outline"
                            app:boxCornerRadiusTopStart="2dp"
                            app:boxCornerRadiusTopEnd="2dp"
                            app:boxCornerRadiusBottomStart="2dp"
                            app:boxCornerRadiusBottomEnd="2dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etCoilNo"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:padding="14dp"
                                android:textColor="#111827"
                                android:textSize="15sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Add Coil Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAddCoil"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="16dp"
                            android:text="Add Coil"
                            android:textAllCaps="false"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:backgroundTint="#1A73E8"
                            app:cornerRadius="5dp" />

                        <!-- RecyclerView -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvCoilList"
                            android:layout_width="match_parent"
                            android:layout_height="250dp"
                            android:layout_marginTop="18dp"
                            android:clipToPadding="false"
                            android:nestedScrollingEnabled="false"
                            android:paddingBottom="8dp" />

                        <!-- Submit Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFinalSubmit"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:layout_marginTop="18dp"
                            android:text="Submit All Coils"
                            android:textAllCaps="false"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:backgroundTint="#16A34A"
                            app:cornerRadius="5dp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>