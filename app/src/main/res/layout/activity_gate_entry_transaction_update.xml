<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <!-- Header -->
        <include
            android:id="@+id/idLayoutHeader"
            layout="@layout/action_bar_comman_hedaer_layout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Main Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="12dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:layout_constraintTop_toBottomOf="@id/idLayoutHeader"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp"
                android:background="@color/lightblue">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gate Entry Details"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <!-- Gate Entry No (Highlight) -->
                    <TextView
                        android:id="@+id/tvGateEntryNo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Gate Entry No: A126E00010"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"
                        android:padding="12dp"
                        android:background="@drawable/bg_gate_entry_badge"
                        android:layout_marginBottom="16dp"/>

                    <!-- Transporter -->
                    <TextView
                        android:id="@+id/tvTransporter"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Transporter: GEA1001"
                        android:textSize="16sp"
                        android:layout_marginTop="8dp"/>

                    <!-- Transporter No -->
                    <TextView
                        android:id="@+id/tvTransporterNo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Transporter Code: 1500101"
                        android:textSize="16sp"
                        android:layout_marginTop="4dp"/>

                    <!-- Vehicle -->
                    <TextView
                        android:id="@+id/tvVehicle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Vehicle: MH04XY5678"
                        android:textSize="16sp"
                        android:layout_marginTop="4dp"/>

                    <!-- LR No -->
                    <TextView
                        android:id="@+id/tvLrNo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="LR No: 7412586368"
                        android:textSize="16sp"
                        android:layout_marginTop="4dp"/>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@android:color/darker_gray"
                        android:layout_marginVertical="16dp"/>

                    <!-- Coil Section Title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Add Coil"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/layoutCoilSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible"
                    android:layout_marginTop="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Coil No">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etCoilNo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnAddCoil"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Add Coil"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/button_generate"
                        android:textColor="@android:color/white" />
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvCoilList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:nestedScrollingEnabled="false"
                        android:visibility="visible"/>

                        <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnFinalSubmit"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Submit All Coils"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/button_generate"
                        android:textColor="@android:color/white" />
                </LinearLayout></LinearLayout>

            </androidx.core.widget.NestedScrollView>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>