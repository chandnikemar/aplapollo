<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="6dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="5dp"
    app:cardElevation="1dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E5E7EB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- TOP ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                <TextView
                    android:id="@+id/tvBarcode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LX2605161264"
                    android:textColor="#111827"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvGrnDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="04-Jun-2026"
                        android:textColor="#6B7280"
                        android:textSize="10sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvSupplierName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Tata Steel Ltd"
                    android:textColor="#6B7280"
                    android:textSize="11sp"/>
            </LinearLayout>

            <!-- QC Approved Badge -->
            <TextView
                android:id="@+id/tvQcStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QC APPROVED"
                android:textColor="#16A34A"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/status_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="6dp"
            android:background="#ECECEC"/>

        <!-- DETAILS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Batch No -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Batch No"
                    android:textColor="#6B7280"
                    android:textSize="10sp"/>

                <TextView
                    android:id="@+id/tvSupplierBatchNo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BT00125"
                    android:textColor="#111827"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Grade -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Grade"
                    android:textColor="#6B7280"
                    android:textSize="10sp"/>

                <TextView
                    android:id="@+id/tvGrade"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="E250"
                    android:textColor="#111827"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Thickness -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thickness"
                    android:textColor="#6B7280"
                    android:textSize="10sp"/>

                <TextView
                    android:id="@+id/tvThickness"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.45"
                    android:textColor="#111827"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>

<!--            &lt;!&ndash; GRN No &ndash;&gt;-->
<!--            <LinearLayout-->
<!--                android:layout_width="0dp"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:layout_weight="1"-->
<!--                android:orientation="vertical">-->

<!--                <TextView-->
<!--                    android:layout_width="wrap_content"-->
<!--                    android:layout_height="wrap_content"-->
<!--                    android:text="GRN No"-->
<!--                    android:textColor="#6B7280"-->
<!--                    android:textSize="10sp"/>-->

<!--                <TextView-->
<!--                    android:id="@+id/tvGrnNo"-->
<!--                    android:layout_width="wrap_content"-->
<!--                    android:layout_height="wrap_content"-->
<!--                    android:text="GRN00125"-->
<!--                    android:textColor="#111827"-->
<!--                    android:textSize="12sp"-->
<!--                    android:textStyle="bold"/>-->
<!--            </LinearLayout>-->

        </LinearLayout>

<!--        &lt;!&ndash; GRN DATE &ndash;&gt;-->
<!--        <TextView-->
<!--            android:id="@+id/tvGrnDate"-->
<!--            android:layout_width="wrap_content"-->
<!--            android:layout_height="wrap_content"-->
<!--            android:layout_marginTop="6dp"-->
<!--            android:text="GRN Date : 04-Jun-2026"-->
<!--            android:textColor="#6B7280"-->
<!--            android:textSize="10sp"/>-->

        <!-- REPRINT BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReprint"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_gravity="end"
            android:layout_marginTop="8dp"
            android:minHeight="32dp"
            android:text="Reprint"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:textStyle="bold"
            app:backgroundTint="@color/secondaryColor"
            app:cornerRadius="5dp"
            app:icon="@drawable/ic_print"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            app:iconTint="@android:color/white"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>