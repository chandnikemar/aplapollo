<?xml version="1.0" encoding="utf-8"?>
<layout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primaryLight">

    <include
        android:id="@+id/idLayoutHeader"
        layout="@layout/action_bar_comman_hedaer_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/idLayoutHeader"
        app:layout_constraintBottom_toTopOf="@+id/btnSubmit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 🔷 Blue Section -->
            <TableLayout
                android:id="@+id/tableLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="*"
                android:background="@color/transparent_grey"
                android:padding="12dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                >

                <!-- ROW 1 -->
                <TableRow android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="3"
                        android:layout_height="48dp"
                        android:layout_marginEnd="8dp"
                        android:text="Operator"
                        android:textColor="@android:color/white"
                        android:gravity="center"
                        android:background="@drawable/rectangle_background_white"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/textOperator"
                        android:layout_width="0dp"
                        android:layout_weight="7"
                        android:layout_height="48dp"
                        android:text="Chandni Jha"
                        android:textColor="@android:color/white"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:background="@drawable/rectangle_background_white"/>
                </TableRow>

                <!-- ROW 2 -->
                <TableRow android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="3"
                        android:layout_height="match_parent"
                        android:text="Location"
                        android:textColor="@android:color/white"
                        android:gravity="center"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/rectangle_background_white"
                        android:textStyle="bold"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_weight="7"
                        android:layout_height="48dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:endIconMode="dropdown_menu"
                        app:boxBackgroundColor="@android:color/white"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/dropdownStation"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="Select Station"
                            android:textColor="@android:color/black"
                            android:inputType="none"
                            android:paddingStart="12dp"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </TableRow>

                <!-- ROW 3 -->
                <TableRow android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="3"
                        android:layout_height="match_parent"
                        android:text="Process"
                        android:textColor="@android:color/white"
                        android:gravity="center"

                        android:background="@drawable/rectangle_background_white"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_weight="7"
                        android:layout_height="48dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:endIconMode="dropdown_menu"
                        app:boxBackgroundColor="@android:color/white"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/dropdownProcess"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="Select Process"
                            android:textColor="@android:color/black"
                            android:inputType="none"
                            android:paddingStart="12dp"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </TableRow>

                <TableRow android:id="@+id/machineRW"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="3"
                        android:layout_height="match_parent"
                        android:text="Machine"
                        android:textColor="@android:color/white"
                        android:gravity="center"
                        android:background="@drawable/rectangle_background_white"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_weight="7"
                        android:layout_height="48dp"
                        app:endIconMode="dropdown_menu"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxBackgroundColor="@android:color/white"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/machineName"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint=" Machine Name"
                            android:textColor="@android:color/black"
                            android:inputType="none"
                            android:paddingStart="12dp"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </TableRow>

            </TableLayout>



        </LinearLayout>
    </ScrollView>

    <!-- 🔘 Submit Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubmit"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:text="Submit"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        android:backgroundTint="@color/orange"
        android:layout_margin="12dp"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
</layout>