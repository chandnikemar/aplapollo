<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/commanBatchDetails"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="1dp">

    <!-- ================= HEADER ================= -->
    <LinearLayout
        android:id="@+id/headerSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/primaryLight"
        android:padding="10dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Material Code"
            android:textSize="12sp"
            android:textColor="@color/primaryDark"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvItemCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/primaryDark"/>
    </LinearLayout>

    <!-- ================= ROW 1 ================= -->
    <TextView
        android:id="@+id/labelGrade"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Grade :"
        android:textStyle="bold"
        android:paddingTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/headerSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tvGrade" />

    <TextView
        android:id="@+id/tvGrade"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:paddingTop="10dp"
        app:layout_constraintTop_toTopOf="@id/labelGrade"
        app:layout_constraintStart_toEndOf="@id/labelGrade"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ================= ROW 2 ================= -->
    <TextView
        android:id="@+id/labelWidth"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Width :"
        android:textStyle="bold"
        android:paddingTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/labelGrade"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tvWidth" />

    <TextView
        android:id="@+id/tvWidth"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:paddingTop="10dp"
        app:layout_constraintTop_toTopOf="@id/labelWidth"
        app:layout_constraintStart_toEndOf="@id/labelWidth"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ================= ROW 3 ================= -->
    <TextView
        android:id="@+id/labelSupplier"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Supplier Batch No :"
        android:textStyle="bold"
        android:paddingTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/labelWidth"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tvSupplierBatchNo" />

    <TextView
        android:id="@+id/tvSupplierBatchNo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:paddingTop="10dp"
        app:layout_constraintTop_toTopOf="@id/labelSupplier"
        app:layout_constraintStart_toEndOf="@id/labelSupplier"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ================= ROW 4 ================= -->
    <TextView
        android:id="@+id/labelWeight"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Weight(Tons) :"
        android:textStyle="bold"
        android:paddingTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/labelSupplier"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tvWeight" />

    <TextView
        android:id="@+id/tvWeight"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingTop="10dp"
        android:text=""
        app:layout_constraintTop_toTopOf="@id/labelWeight"
        app:layout_constraintStart_toEndOf="@id/labelWeight"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ================= ROW 5 ================= -->
    <TextView
        android:id="@+id/labelThickness"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Thickness :"

        android:textStyle="bold"
        android:paddingTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/labelWeight"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tvThickness" />

    <TextView
        android:id="@+id/tvThickness"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:paddingTop="10dp"
        app:layout_constraintTop_toTopOf="@id/labelThickness"
        app:layout_constraintStart_toEndOf="@id/labelThickness"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>