<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_margin="8dp"
    android:background="@color/primaryLight">

    <!-- 🔷 Material Section -->
    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stretchColumns="*"
        android:background="@color/transparent_grey"
        android:padding="12dp">

        <!-- Material -->
        <TableRow android:layout_marginBottom="10dp">

<!--             <TextView-->
<!--            android:layout_width="0dp"-->
<!--            android:layout_weight="4"-->
<!--            android:layout_height="40dp"-->
<!--            android:text="OUTPUT"-->
<!--            android:textColor="@android:color/white"-->
<!--            android:gravity="center"-->
<!--            android:background="@drawable/rectangle_background_white"-->
<!--            android:textStyle="bold"/>-->

            <com.google.android.material.textfield.TextInputLayout
                android:layout_weight="7"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:endIconMode="dropdown_menu"
                app:boxBackgroundColor="@android:color/white">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/dropdownMaterial"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="Select Material"
                    android:textColor="@android:color/black"
                    android:inputType="none"
                    android:paddingStart="12dp"/>
            </com.google.android.material.textfield.TextInputLayout>

        </TableRow>

        <!-- Barcode + Weight -->
        <TableRow android:layout_marginBottom="10dp">

            <!-- Barcode (60%) -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_weight="6"
                android:hint="Barcode"
                app:hintTextColor="@color/white"
                app:boxBackgroundColor="@android:color/transparent">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etBarcode"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@drawable/rectangle_background_white"
                    android:enabled="false"
                    android:text="BR0123456789YU"
                    android:textColor="@android:color/white"
                    android:textColorHint="@android:color/white"
                    android:padding="10dp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Weight (40%) -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_weight="4"
                android:hint="Weight"
                android:layout_marginStart="6dp"
                app:boxBackgroundColor="@android:color/transparent">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etWeights"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@drawable/rectangle_background_white"
                    android:inputType="numberDecimal"
                    android:textColor="@android:color/white"
                    android:textColorHint="@android:color/white"
                    android:padding="10dp"/>
            </com.google.android.material.textfield.TextInputLayout>


    </TableRow>
    </TableLayout>

    <!-- 🔷 FG Section -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FG Details"
                android:textStyle="bold"
                android:textColor="@color/primaryDark"
                android:layout_marginBottom="10dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFGList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>