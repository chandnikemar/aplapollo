<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F4F7FC">

        <!-- ================= HEADER ================= -->
        <include
            android:id="@+id/idLayoutHeader"
            layout="@layout/action_bar_comman_hedaer_layout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ================= CONTENT ================= -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:padding="14dp"
            app:layout_constraintTop_toBottomOf="@id/idLayoutHeader"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Top Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Screen Title -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gate Entry"
                        android:textColor="#111827"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Manage and update gate entries"
                        android:textColor="#6B7280"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Add Button -->
                <!-- Add Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnInProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="46dp"
                    android:text="Add Entry"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/primaryDark"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_add"
                    app:iconTint="@android:color/white"
                    app:iconPadding="6dp"
                    android:paddingHorizontal="14dp" />

            </LinearLayout>

            <!-- History Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="10dp"
                android:text="Gate Entry History"
                android:textColor="#111827"
                android:textSize="17sp"
                android:textStyle="bold" />

            <!-- Empty State -->

            <LinearLayout
                android:id="@+id/layoutEmptyState"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="40dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:alpha="0.8"
                    android:src="@drawable/ic_empty_box" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="No Gate Entries Found"
                    android:textColor="#111827"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:text="No gate entry transactions are available.\nTap Add Entry to create a new one."
                    android:textColor="#6B7280"
                    android:textSize="13sp" />

            </LinearLayout>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvGateEntryHistory"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"

                    tools:listitem="@layout/item_gate_entry_history" />



        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>