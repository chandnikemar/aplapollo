<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
   >

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- HEADER -->
            <include
                android:id="@+id/idLayoutHeader"
                layout="@layout/action_bar_comman_hedaer_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- INPUT ROW -->
            <include
                android:id="@+id/commanInputRow"
                layout="@layout/comman_inputrow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:layout_constraintTop_toBottomOf="@id/idLayoutHeader"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- BATCH DETAILS -->
            <LinearLayout
                android:id="@+id/layoutBatchDetails"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:orientation="vertical"
                android:padding="10dp"
                app:layout_constraintTop_toBottomOf="@id/commanInputRow"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- TABLE -->
                <include
                    android:id="@+id/inCommanBatch"
                    layout="@layout/comman_batchdetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <!-- DIVIDER -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:background="#DDDDDD" />

            <LinearLayout
                android:id="@+id/TvItemThickness"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                app:layout_constraintTop_toBottomOf="@id/inCommanBatch"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <!-- Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Desired Thickness:"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:layout_marginEnd="4dp" />

                <!-- Value -->
                <EditText
                    android:id="@+id/etDesiredThickness"
                    android:layout_width="120dp"
                    android:layout_height="40dp"
                    android:backgroundTint="@color/blue"
                    android:background="@drawable/edittext_bg"
                    android:hint="0.0"

                    android:textColorHint="@android:color/white"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:inputType="numberDecimal"
                    android:padding="6dp" />
            </LinearLayout>

                <!-- SAVE / CLEAR BUTTONS -->
                <LinearLayout
                    android:id="@+id/layoutActionButtons"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btncSaves"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Save"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        app:backgroundTint="@color/green"
                        android:layout_marginEnd="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btncClears"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Clear"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        app:backgroundTint="@color/orange"
                        android:layout_marginStart="8dp" />

                </LinearLayout>


                <!--            <LinearLayout-->
                <!--                android:id="@+id/layoutActionButtons"-->
                <!--                android:layout_width="match_parent"-->
                <!--                android:layout_height="wrap_content"-->
                <!--                android:orientation="horizontal"-->
                <!--                android:gravity="center"-->
                <!--                android:layout_marginTop="20dp">-->

                <!--                <androidx.appcompat.widget.AppCompatButton-->
                <!--                    android:id="@+id/btnSave"-->
                <!--                    android:layout_width="0dp"-->
                <!--                    android:layout_height="48dp"-->
                <!--                    android:layout_weight="1"-->
                <!--                    android:text="Save"-->
                <!--                    android:textAllCaps="false"-->
                <!--                    android:textColor="@android:color/white"-->
                <!--                    android:background="@drawable/button_generate"-->
                <!--                    android:layout_marginEnd="8dp"/>-->

                <!--                <androidx.appcompat.widget.AppCompatButton-->
                <!--                    android:id="@+id/btnClear"-->
                <!--                    android:layout_width="0dp"-->
                <!--                    android:layout_height="48dp"-->
                <!--                    android:layout_weight="1"-->
                <!--                    android:text="Clear"-->
                <!--                    android:textAllCaps="false"-->
                <!--                    android:textColor="@android:color/white"-->
                <!--                    android:background="@drawable/button_clear"-->
                <!--                    android:layout_marginStart="8dp"/>-->
                <!--            </LinearLayout>-->
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</layout>
